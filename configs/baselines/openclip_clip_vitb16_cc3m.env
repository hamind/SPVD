# OpenCLIP CLIP baseline config for the detected CC3M WebDataset shards.

MODEL=${MODEL:-ViT-B-16}
PRETRAINED=${PRETRAINED:-}
if [ -z "${TRAIN_DATA:-}" ]; then
  TRAIN_DATA='/vepfs/dataset/cc3m/cc3m-train-{0000..0575}.tar'
fi
DATASET_TYPE=${DATASET_TYPE:-webdataset}

# Estimated from the detected 576 CC3M train shards. Override if an exact
# count is computed later.
TRAIN_NUM_SAMPLES=${TRAIN_NUM_SAMPLES:-2906495}

BATCH_SIZE=${BATCH_SIZE:-640}
WORKERS=${WORKERS:-11}
PREFETCH_FACTOR=${PREFETCH_FACTOR:-2}
EPOCHS=${EPOCHS:-32}
LR=${LR:-5e-4}
WD=${WD:-0.2}
BETA1=${BETA1:-0.9}
BETA2=${BETA2:-0.98}
EPS=${EPS:-1e-6}
WARMUP=${WARMUP:-2000}
ACCUM_FREQ=${ACCUM_FREQ:-1}
PRECISION=${PRECISION:-amp}
FORCE_IMAGE_SIZE=${FORCE_IMAGE_SIZE:-224}
SEED=${SEED:-42}

LOGS=${LOGS:-outputs/baselines/openclip}
SAVE_FREQUENCY=${SAVE_FREQUENCY:-1}
LOG_EVERY_N_STEPS=${LOG_EVERY_N_STEPS:-50}
REPORT_TO=${REPORT_TO:-none}

LOCAL_LOSS=${LOCAL_LOSS:-1}
GATHER_WITH_GRAD=${GATHER_WITH_GRAD:-1}
GRAD_CHECKPOINTING=${GRAD_CHECKPOINTING:-0}
EXTRA_ARGS=${EXTRA_ARGS:-}
